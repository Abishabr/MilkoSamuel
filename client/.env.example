# Client-side environment variables (React + Vite)
# Copy this file to .env and fill in real values before starting the dev server.

# Supabase → Settings → API (used ONLY for admin login/auth — safe for browser)
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Cloudinary → Dashboard (unsigned upload preset: Settings → Upload → Add preset)
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name-here
VITE_CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset-here

# Deployed API origin — leave EMPTY for local dev (Vite proxy handles /api).
# On Vercel set this to your Render API URL, e.g. https://milkosamuel-api.onrender.com
VITE_API_URL=
