# Server-side environment variables (Express.js backend)
# Copy this file to .env and fill in real values before starting the server.

# Supabase → Settings → API → Project URL
SUPABASE_URL=your-supabase-url-here

# Supabase → Settings → API → service_role key (NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Port the API listens on (Render/Railway inject PORT automatically)
PORT=3001

# Comma-separated list of allowed browser origins (no trailing slashes)
# Local dev + deployed frontend:
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app
